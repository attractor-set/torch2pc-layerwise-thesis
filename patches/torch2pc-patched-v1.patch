+from __future__ import annotations
+
+import argparse
+import copy
+import importlib.util
+import statistics
+import time
+from pathlib import Path
+from types import ModuleType
+
+import torch
+import torch.nn as nn
+
+
+def load_module(name: str, path: Path) -> ModuleType:
+    spec = importlib.util.spec_from_file_location(name, path)
+    if spec is None or spec.loader is None:
+        raise RuntimeError(f"Cannot import {path}")
+    module = importlib.util.module_from_spec(spec)
+    spec.loader.exec_module(module)
+    return module
+
+
+def model() -> nn.Sequential:
+    return nn.Sequential(
+        nn.Sequential(nn.Conv2d(1, 6, 5), nn.Tanh(), nn.AvgPool2d(2, 2)),
+        nn.Sequential(nn.Conv2d(6, 16, 5), nn.Tanh(), nn.AvgPool2d(2, 2)),
+        nn.Flatten(),
+        nn.Sequential(nn.Linear(16 * 5 * 5, 120), nn.Tanh()),
+        nn.Sequential(nn.Linear(120, 84), nn.Tanh()),
+        nn.Linear(84, 10),
+    )
+
+
+def synchronize(device: torch.device) -> None:
+    if device.type == "cuda":
+        torch.cuda.synchronize(device)
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--module", type=Path, default=Path("TorchSeq2PC.py"))
+    parser.add_argument("--device", choices=["cpu", "cuda"], default="cpu")
+    parser.add_argument("--batch-size", type=int, default=256)
+    parser.add_argument("--warmup", type=int, default=3)
+    parser.add_argument("--repetitions", type=int, default=10)
+    args = parser.parse_args()
+
+    device = torch.device(args.device)
+    implementation = load_module("torch2pc_benchmark_candidate", args.module)
+    base = model().to(device)
+    inputs = torch.randn(args.batch_size, 1, 32, 32, device=device)
+    targets = torch.randint(0, 10, (args.batch_size,), device=device)
+    loss_fn = nn.CrossEntropyLoss()
+
+    for method, eta, steps in [
+        ("Exact", 0.1, 20),
+        ("FixedPred", 0.1, 10),
+        ("Strict", 0.05, 20),
+    ]:
+        samples: list[float] = []
+        for repetition in range(args.warmup + args.repetitions):
+            candidate = copy.deepcopy(base)
+            synchronize(device)
+            started = time.perf_counter()
+            implementation.PCInfer(
+                candidate,
+                loss_fn,
+                inputs,
+                targets,
+                method,
+                eta=eta,
+                n=steps,
+            )
+            synchronize(device)
+            elapsed = time.perf_counter() - started
+            if repetition >= args.warmup:
+                samples.append(elapsed)
+        print(
+            method,
+            {
+                "median_sec": statistics.median(samples),
+                "mean_sec": statistics.fmean(samples),
+                "min_sec": min(samples),
+                "max_sec": max(samples),
+            },
+        )
+
+
+if __name__ == "__main__":
+    main()
