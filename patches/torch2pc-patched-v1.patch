@@ -0,0 +1,175 @@
+from __future__ import annotations
+
+import copy
+import importlib.util
+import os
+import subprocess
+import sys
+from pathlib import Path
+from types import ModuleType
+
+import pytest
+import torch
+import torch.nn as nn
+
+DEFAULT_ORIGINAL_COMMIT = "00c6c50ee3540537bbb56ab2b6567b541f42b093"
+
+
+def _load_module(name: str, path: Path) -> ModuleType:
+    spec = importlib.util.spec_from_file_location(name, path)
+    if spec is None or spec.loader is None:
+        raise RuntimeError(f"Cannot import {path}")
+    module = importlib.util.module_from_spec(spec)
+    sys.modules[name] = module
+    spec.loader.exec_module(module)
+    return module
+
+
+@pytest.fixture(scope="session")
+def implementations(tmp_path_factory: pytest.TempPathFactory) -> tuple[ModuleType, ModuleType]:
+    root = Path(__file__).resolve().parents[1]
+    original_commit = os.environ.get(
+        "TORCH2PC_ORIGINAL_COMMIT", DEFAULT_ORIGINAL_COMMIT
+    )
+    try:
+        original_source = subprocess.check_output(
+            ["git", "show", f"{original_commit}:TorchSeq2PC.py"],
+            cwd=root,
+            text=True,
+            stderr=subprocess.STDOUT,
+        )
+    except subprocess.CalledProcessError as exc:
+        pytest.fail(
+            "Original Torch2PC commit is unavailable. Base the patch branch on "
+            f"{DEFAULT_ORIGINAL_COMMIT} or set TORCH2PC_ORIGINAL_COMMIT.\n{exc.output}"
+        )
+    reference_path = tmp_path_factory.mktemp("torch2pc-reference") / "TorchSeq2PC.py"
+    reference_path.write_text(original_source, encoding="utf-8")
+    return (
+        _load_module("torch2pc_original_reference", reference_path),
+        _load_module("torch2pc_patched_candidate", root / "TorchSeq2PC.py"),
+    )
+
+
+def _model() -> nn.Sequential:
+    return nn.Sequential(
+        nn.Linear(4, 6),
+        nn.Tanh(),
+        nn.Linear(6, 3),
+    ).double()
+
+
+def _assert_tensor_lists_close(
+    reference: list[torch.Tensor | None],
+    candidate: list[torch.Tensor | None],
+) -> None:
+    assert len(reference) == len(candidate)
+    for left, right in zip(reference, candidate, strict=True):
+        if left is None or right is None:
+            assert left is right
+            continue
+        torch.testing.assert_close(left, right, rtol=1e-10, atol=1e-12)
+
+
+@pytest.mark.parametrize(
+    ("method", "eta", "steps"),
+    [
+        ("Exact", 0.1, 20),
+        ("FixedPred", 0.1, 5),
+        ("Strict", 0.05, 5),
+    ],
+)
+def test_patched_pc_infer_matches_original(
+    implementations: tuple[ModuleType, ModuleType],
+    method: str,
+    eta: float,
+    steps: int,
+) -> None:
+    original, patched = implementations
+    torch.manual_seed(11)
+    base = _model()
+    reference_model = copy.deepcopy(base)
+    candidate_model = copy.deepcopy(base)
+    inputs = torch.randn(8, 4, dtype=torch.float64)
+    targets = torch.randint(0, 3, (8,))
+    loss_fn = nn.CrossEntropyLoss()
+
+    reference = original.PCInfer(
+        reference_model, loss_fn, inputs, targets, method, eta=eta, n=steps
+    )
+    candidate = patched.PCInfer(
+        candidate_model, loss_fn, inputs, targets, method, eta=eta, n=steps
+    )
+
+    torch.testing.assert_close(reference[1], candidate[1], rtol=1e-12, atol=1e-12)
+    torch.testing.assert_close(reference[2], candidate[2], rtol=1e-10, atol=1e-12)
+    _assert_tensor_lists_close(reference[3], candidate[3])
+    _assert_tensor_lists_close(reference[4], candidate[4])
+    for reference_parameter, candidate_parameter in zip(
+        reference_model.parameters(), candidate_model.parameters(), strict=True
+    ):
+        assert reference_parameter.grad is not None
+        assert candidate_parameter.grad is not None
+        torch.testing.assert_close(
+            reference_parameter.grad,
+            candidate_parameter.grad,
+            rtol=1e-10,
+            atol=1e-12,
+        )
+
+
+def test_exact_gradients_match_backprop(
+    implementations: tuple[ModuleType, ModuleType],
+) -> None:
+    _, patched = implementations
+    torch.manual_seed(19)
+    bp_model = _model()
+    exact_model = copy.deepcopy(bp_model)
+    inputs = torch.randn(8, 4, dtype=torch.float64)
+    targets = torch.randint(0, 3, (8,))
+    loss_fn = nn.CrossEntropyLoss()
+
+    loss_fn(bp_model(inputs), targets).backward()
+    patched.PCInfer(exact_model, loss_fn, inputs, targets, "Exact")
+
+    for bp_parameter, exact_parameter in zip(
+        bp_model.parameters(), exact_model.parameters(), strict=True
+    ):
+        assert bp_parameter.grad is not None
+        assert exact_parameter.grad is not None
+        torch.testing.assert_close(
+            bp_parameter.grad,
+            exact_parameter.grad,
+            rtol=1e-10,
+            atol=1e-12,
+        )
+
+
+def test_strict_uses_explicit_vinit(
+    implementations: tuple[ModuleType, ModuleType],
+) -> None:
+    _, patched = implementations
+    torch.manual_seed(23)
+    model = _model()
+    inputs = torch.randn(8, 4, dtype=torch.float64)
+    targets = torch.randint(0, 3, (8,))
+    loss_fn = nn.CrossEntropyLoss()
+    vhat, _, _ = patched.FwdPassPlus(model, loss_fn, inputs, targets)
+    custom = [value.detach().clone() for value in vhat]
+    custom[1] = custom[1] + 0.25
+
+    _, _, _, default_v, _ = patched.PCInfer(
+        copy.deepcopy(model), loss_fn, inputs, targets, "Strict", eta=0.05, n=1
+    )
+    _, _, _, custom_v, _ = patched.PCInfer(
+        copy.deepcopy(model),
+        loss_fn,
+        inputs,
+        targets,
+        "Strict",
+        eta=0.05,
+        n=1,
+        vinit=custom,
+    )
+
+    assert not torch.equal(default_v[1], custom_v[1])
